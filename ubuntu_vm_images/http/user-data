autoinstall:
  version: 1
  
  locale: en_US.UTF-8
  keyboard:
    layout: us
  
  identity:
    hostname: ubuntu-template
    username: ubuntu
    password: '$6$azsi3dgBw0T0Ae0E$GZkOZhC7xwnU6CbU0jtECQ3YB.Y9.eLoKZXxS/bCFCKUGD3DQv9A1A0cOWYpRccN8EWCluVEnauT264us7U3u.'
  
  ssh:
